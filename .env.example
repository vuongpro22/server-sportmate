# --- MongoDB (bắt buộc — server chỉ đọc từ đây, không còn URI mặc định trong code) ---
MONGODB_URI=mongodb://127.0.0.1:27017/sportmate

# --- SMTP (Gmail) — tương đương Spring Boot ---
#
#   Spring                              →  Biến .env (Node / nodemailer)
#   ─────────────────────────────────────────────────────────────────────
#   spring.mail.host                    →  SMTP_HOST
#   spring.mail.port                    →  SMTP_PORT
#   spring.mail.username                →  SMTP_USER
#   spring.mail.password                →  SMTP_PASS
#   spring.mail.properties.mail.smtp... →  Không cần: với port 587, nodemailer
#                                         dùng STARTTLS + auth mặc định
#                                         (tương đương starttls.enable=true)
#
# App Password Gmail: 16 ký tự — có thể dán kèm khoảng trắng, server sẽ tự gỡ
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# false = dùng STARTTLS trên cổng 587 (giống spring starttls.enable=true)
SMTP_SECURE=false
SMTP_USER=warmhouse.charity.contact@gmail.com
SMTP_PASS=your_16_char_app_password_no_spaces
SMTP_FROM="SportMate <warmhouse.charity.contact@gmail.com>"

PORT=3000

# Chat message encryption key (AES-256-GCM, 32 bytes = 64 hex chars)
# Generate your own: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER share or commit the actual key
CHAT_ENCRYPTION_KEY=your_64_char_hex_key_here
